# AIOps Agent 配置
# 复制此文件为 .env 并填入实际值

# LLM Provider（当前仅支持 openai_compatible）
LLM_PROVIDER=openai_compatible

# OpenAI 兼容接口配置
# 支持: OpenAI / DeepSeek / 通义千问 / 硅基流动 等
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名称（默认 gpt-4o-mini）
OPENAI_MODEL=gpt-4o-mini

# Agent 设置
SYSTEM_PROMPT=你是一个 AIOps 运维助手，擅长通过工具执行运维任务。
MAX_TOOL_ROUNDS=10

# Memory 配置（三层记忆）
MEMORY_STRATEGY=tiered          # tiered | none
MEMORY_MAX_MESSAGES=30          # 工作记忆最大消息数
MEMORY_MAX_TOKENS=8000          # 工作记忆 token 阈值
MEMORY_MAX_EPISODES=50          # 情景记忆最大存储数
MEMORY_RECENT_EPISODES=3        # 上下文中包含的最近情景数
MEMORY_COMPACTION_ENABLED=true  # 是否启用自动压缩
